{
  "model_version": "decision-support-v2",
  "purpose": "More selective human-review buy, add, hold, review, and trim alerts",
  "signal_weights": {
    "trend": 0.25,
    "momentum": 0.2,
    "quality": 0.25,
    "valuation": 0.2,
    "revisions": 0.1
  },
  "buy_candidate_threshold": 0.5,
  "require_revisions_for_buy": true,
  "selectivity_rules": {
    "drawdown_review_threshold": -0.3,
    "severe_drawdown_threshold": -0.5,
    "negative_trend_threshold": -0.5,
    "negative_revisions_threshold": -0.5,
    "trim_score_threshold": -0.25,
    "minimum_deterioration_signals": 2
  },
  "rationale": "Require confirmation across deterioration signals, while preserving standalone severe drawdown, concentration, and broken-thesis reviews.",
  "promotion_status": "experimental",
  "evaluation": {
    "forward_sessions": [21, 63, 126],
    "minimum_episode_sessions": 21,
    "same_close_execution": false
  }
}
